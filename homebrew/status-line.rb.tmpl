class StatusLine < Formula
  desc "Three-line styled terminal status bar for Claude Code"
  homepage "https://github.com/zehuac2/status-line"
  version "{{VERSION}}"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/zehuac2/status-line/releases/download/{{TAG}}/status-line-darwin-arm64.tar.gz"
      sha256 "{{SHA256_DARWIN_ARM64}}"
    else
      odie "status-line only publishes an Apple Silicon (arm64) build for macOS"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/zehuac2/status-line/releases/download/{{TAG}}/status-line-linux-arm64.tar.gz"
      sha256 "{{SHA256_LINUX_ARM64}}"
    else
      url "https://github.com/zehuac2/status-line/releases/download/{{TAG}}/status-line-linux-x64.tar.gz"
      sha256 "{{SHA256_LINUX_X64}}"
    end
  end

  def install
    bin.install "status-line"
  end

  test do
    system "#{bin}/status-line", "-claude"
  end
end
